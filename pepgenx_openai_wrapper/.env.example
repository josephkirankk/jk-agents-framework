# PepGenX API Configuration
PEPGENX_API_URL=https://your-pepgenx-api-endpoint.com/api/generate
PEPGENX_PROJECT_ID=your-project-id
PEPGENX_TEAM_ID=your-team-id
PEPGENX_API_KEY=your-pepgenx-api-key

# OKTA Token Configuration
OKTA_TOKEN_FILE=okta_token.json

# OpenAI Wrapper Configuration
OPENAI_WRAPPER_API_KEYS=sk-wrapper-key1,sk-wrapper-key2,sk-wrapper-key3
OPENAI_WRAPPER_HOST=0.0.0.0
OPENAI_WRAPPER_PORT=8080

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS Configuration
CORS_ORIGINS=*
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=*

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Security
SECRET_KEY=your-secret-key-for-jwt-signing
TOKEN_EXPIRE_MINUTES=30

# Cache Configuration
CACHE_TTL_SECONDS=300
OKTA_TOKEN_REFRESH_THRESHOLD_MINUTES=5
