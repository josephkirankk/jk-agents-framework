# ============================================================================
# MULTI-PROVIDER OPENAI CONFIGURATION
# ============================================================================
# This configuration supports using multiple OpenAI providers simultaneously:
# - Regular OpenAI API (openai:model-name)
# - Azure OpenAI (azure_openai:deployment-name)
# - Local LM Studio (openai:model-name with OPENAI_BASE_URL)
#
# MODEL NAMING CONVENTIONS:
# - OpenAI API models: "openai:gpt-4o-mini", "openai:gpt-4o", "openai:gpt-3.5-turbo"
# - Azure OpenAI models: "azure_openai:your-deployment-name"
# - Anthropic Claude models: "anthropic:claude-sonnet-4-20250514", "anthropic:claude-opus-4-20250514"
# - Local LM Studio models: "openai:model-name" (uses OPENAI_BASE_URL)
#
# PROVIDER SELECTION LOGIC:
# 1. azure_openai:* models always use Azure OpenAI (if configured)
# 2. anthropic:* models always use Anthropic Claude API (if configured)
# 3. openai:* models use:
#    - Local server if OPENAI_BASE_URL is set
#    - OpenAI API if only OPENAI_API_KEY is set
#    - Auto-convert to azure_openai:* if Azure vars are set (no OPENAI_BASE_URL)
# 4. You can mix providers by explicitly using prefixes
# ============================================================================

# === REGULAR OPENAI API ===
# Uncomment to use OpenAI's official API for openai: prefixed models
# OPENAI_API_KEY=sk-your-openai-api-key-here

# === AZURE OPENAI ===
# Uncomment to use Azure OpenAI for azure_openai: prefixed models
# When these are set WITHOUT OPENAI_BASE_URL, openai: models auto-convert to azure_openai:
AZURE_OPENAI_ENDPOINT=https://pep-aisp-hackathon.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_KEY=xxx
AZURE_OPENAI_API_VERSION=2023-05-15

# === LM STUDIO (OpenAI-compatible local server) ===
# When these are set, openai: models use the local LM Studio server
# This prevents auto-conversion to azure_openai: even if Azure vars are set
OPENAI_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_API_KEY=lm-studio

# === ANTHROPIC CLAUDE ===
# Uncomment to use Anthropic Claude for anthropic: prefixed models
# ANTHROPIC_API_KEY=sk-ant-api03-your-api-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # Optional, defaults to official API

# === EXAMPLE MULTI-PROVIDER CONFIGURATIONS ===

# SCENARIO 1: Azure OpenAI + LM Studio
# Use Azure for production models, LM Studio for local/testing
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# OPENAI_API_KEY=lm-studio
# Then in your YAML config:
# models:
#   default: "azure_openai:gpt-4o-mini"      # Uses Azure OpenAI
#   supervisor: "openai:google/gemma-3n-e4b" # Uses LM Studio
#   local_test: "openai:llama-3.2-3b"        # Uses LM Studio

# SCENARIO 2: Regular OpenAI + Azure OpenAI
# Use both cloud providers (requires explicit model prefixes)
# OPENAI_API_KEY=sk-your-openai-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Then in your YAML config:
# models:
#   default: "openai:gpt-4o-mini"            # Uses regular OpenAI
#   supervisor: "azure_openai:gpt-4o-mini"   # Uses Azure OpenAI

# SCENARIO 3: All three providers
# OPENAI_API_KEY=sk-your-openai-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1  # This enables LM Studio for openai: models
# Then in your YAML config:
# models:
#   default: "openai:google/gemma-3n-e4b"    # Uses LM Studio
#   supervisor: "azure_openai:gpt-4o-mini"   # Uses Azure OpenAI
#   fallback: "openai:gpt-4o-mini"           # Uses LM Studio (due to OPENAI_BASE_URL)

# ============================================================================
# LANGSMITH CONFIGURATION (Optional)
# ============================================================================
# Uncomment to enable LangSmith tracing and monitoring
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=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
LANGSMITH_PROJECT=jk-agents-local

# ============================================================================
# ADDITIONAL OPENAI-COMPATIBLE PROVIDERS
# ============================================================================
# For other OpenAI-compatible services (Ollama, LocalAI, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1  # Ollama
# OPENAI_API_KEY=ollama
#
# OPENAI_BASE_URL=http://localhost:8080/v1   # LocalAI
# OPENAI_API_KEY=localai