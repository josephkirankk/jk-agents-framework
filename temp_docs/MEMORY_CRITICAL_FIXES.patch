# Fix 2: LRUCache Race Condition
# File: app/memory/structures.py

--- a/app/memory/structures.py
+++ b/app/memory/structures.py
@@ -290,20 +290,21 @@ class LRUCache:
     def set(self, key: Any, value: Any) -> None:
         """Set value in cache."""
         with self._lock:
             if key in self._cache:
                 # Update existing node
                 node = self._cache[key]
                 node.value = value
                 self._move_to_head(node)
             else:
-                # Add new node
-                new_node = self._Node(key, value)
-                
+                # Check size and evict BEFORE adding (atomic)
                 if len(self._cache) >= self.maxsize:
                     # Evict least recently used
                     tail = self._pop_tail()
                     del self._cache[tail.key]
                     self._stats["evictions"] += 1
                 
+                # Now safe to add (guaranteed space exists)
+                new_node = self._Node(key, value)
                 self._cache[key] = new_node
                 self._add_node(new_node)

